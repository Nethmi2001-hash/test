# Monastery Healthcare System v2.0 Environment Configuration
# Copy this file to .env and update the values

# Application Settings
APP_NAME="Monastery Healthcare System"
APP_VERSION="2.0.0"
APP_URL="http://localhost/redesign/public"
APP_DEBUG=true
APP_TIMEZONE="Asia/Colombo"

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=monastery_healthcare_v2
DB_USER=root
DB_PASS=

# Security Settings
ENCRYPTION_KEY="change-this-to-a-secure-32-character-key"
SESSION_LIFETIME=1800

# Email Configuration (Optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@monastery.lk
MAIL_FROM_NAME="Monastery Healthcare System"

# File Upload Settings
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES="jpg,jpeg,png,pdf,doc,docx"

# Logging
LOG_LEVEL=debug
LOG_CHANNEL=file